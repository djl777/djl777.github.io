        <content type="html"><![CDATA[<h2 id="list">list</h2><h4 id="弹出最后一个元素">弹出最后一个元素</h4><figure class="highlight plaintext"><table><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><span class="line">grid.pop()</span><br></pre></td></tr></table></figure><p> </p><h4 id="二维数组求最大值">二维数组求最大值</h4><figure class="highlight python"><table><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><span class="line"><span class="built_in">max</span>(<span class="built_in">max</span>(row[j:j+<span class="number">3</span>]) <span class="keyword">for</span> row <span class="keyword">in</span> grid[i:i+<span class="number">3</span>])</span><br></pre></td></tr></table></figure><p> </p><h4 id="同时枚举下标和元素">同时枚举下标和元素</h4><figure class="highlight python"><table><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><span class="line"><span class="keyword">for</span> i,num <span class="keyword">in</span> <span class="built_in">enumerate</span>(grid)</span><br></pre></td></tr></table></figure><p> </p><h4 id="逆序">逆序</h4><figure class="highlight python"><table><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><span class="line">ans[a:b] = ans[a:b][::-<span class="number">1</span>]</span><br></pre></td></tr></table></figure><p> </p><h4 id="元素转str">元素转str</h4><figure class="highlight python"><table><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><span class="line"><span class="string">&#x27;&#x27;</span>.join(ans)</span><br></pre></td></tr></table></figure><p> </p>]]></content>
      
      
